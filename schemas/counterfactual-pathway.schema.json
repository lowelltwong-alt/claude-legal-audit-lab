{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/claude-legal-audit/counterfactual-pathway.schema.json",
  "title": "Candidate counterfactual pathway submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "submission_status", "source_class", "synthetic_only", "collection_enabled",
    "network_access", "stage_id", "pattern_id", "signal_class", "possible_inference",
    "epistemic_status", "source_ids", "source_locators", "alternative_explanations",
    "what_it_cannot_prove", "confidentiality_privilege_privacy_risk", "countercontrols",
    "applies_when", "does_not_apply_when", "danger_if_misapplied", "requires_human_decision"
  ],
  "properties": {
    "schema": {"const": "claude-legal-audit.counterfactual-pathway-submission.v1"},
    "submission_status": {"const": "candidate"},
    "source_class": {"const": "synthetic_or_public_primary_only"},
    "synthetic_only": {"const": true},
    "collection_enabled": {"const": false},
    "network_access": {"const": false},
    "stage_id": {"type": "string", "pattern": "^LF-[0-9]{2}$"},
    "pattern_id": {"type": "string", "pattern": "^CF-[0-9]{3}$"},
    "signal_class": {"type": "string", "minLength": 3},
    "possible_inference": {"type": "string", "minLength": 20},
    "epistemic_status": {"enum": ["observed_fact", "reasoned_inference", "counterfactual_hypothesis", "unknown", "disconfirmed_or_constrained"]},
    "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^SRC-[0-9]{4}$"}},
    "source_locators": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 8}},
    "alternative_explanations": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 8}},
    "what_it_cannot_prove": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 8}},
    "confidentiality_privilege_privacy_risk": {"type": "string", "minLength": 20},
    "countercontrols": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 8}},
    "applies_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 8}},
    "does_not_apply_when": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 8}},
    "danger_if_misapplied": {"type": "string", "minLength": 20},
    "requires_human_decision": {"const": true}
  }
}
