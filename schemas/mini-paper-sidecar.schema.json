{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/claude-legal-audit/mini-paper-sidecar.schema.json",
  "type": "object", "additionalProperties": false,
  "required": ["schema", "revision", "status", "profile", "paper", "inputs", "units", "structure_score", "standard_mappings"],
  "properties": {
    "schema": {"const": "claude-legal-audit.mini-paper-sidecar.v1"},
    "revision": {"const": "1.0.0"}, "status": {"const": "blocked_unpublished_candidate"},
    "profile": {"type": "object", "additionalProperties": false, "required": ["profile_id", "audience", "title", "subtitle"], "properties": {"profile_id": {"enum": ["executive", "academic", "adversarial"]}, "audience": {"type": "string", "minLength": 3}, "title": {"type": "string", "minLength": 3}, "subtitle": {"type": "string", "minLength": 3}}},
    "paper": {"type": "object", "additionalProperties": false, "required": ["path", "sha256"], "properties": {"path": {"type": "string", "pattern": "^public/generated-release-artifacts/candidate/mini-papers/(executive|academic|adversarial)\\.md$"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}}},
    "inputs": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "units": {"type": "array", "minItems": 7, "items": {"$ref": "#/$defs/renderedUnit"}},
    "structure_score": {"$ref": "#/$defs/structureScore"},
    "standard_mappings": {"type": "object", "additionalProperties": false, "required": ["w3c_web_annotation", "w3c_prov", "cito", "jats", "ro_crate", "nanopublication"], "properties": {"w3c_web_annotation": {"type": "string"}, "w3c_prov": {"type": "string"}, "cito": {"type": "string"}, "jats": {"type": "string"}, "ro_crate": {"type": "string"}, "nanopublication": {"type": "string"}}}
  },
  "$defs": {
    "renderedUnit": {
      "type": "object", "additionalProperties": false,
      "required": ["unit_id", "render_id", "profile_id", "section_id", "order", "anchor", "tags", "assertion_ids", "semantic_role", "epistemic_status", "does_not_prove", "genealogy", "genealogy_sha256", "render_sha256", "selector"],
      "properties": {
        "unit_id": {"type": "string", "pattern": "^MPU-[0-9]{4}$"}, "render_id": {"type": "string", "pattern": "^MPR-(executive|academic|adversarial)-[0-9]{4}$"},
        "profile_id": {"enum": ["executive", "academic", "adversarial"]}, "section_id": {"type": "string", "pattern": "^MPS-[0-9]{4}$"}, "order": {"type": "integer", "minimum": 1},
        "anchor": {"type": "string", "pattern": "^mpu-[0-9]{4}$"}, "tags": {"type": "array", "minItems": 3, "uniqueItems": true, "items": {"type": "string"}},
        "assertion_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^CLM-[0-9]{4}$"}},
        "semantic_role": {"type": "string"}, "epistemic_status": {"type": "string"}, "does_not_prove": {"type": "string"},
        "genealogy": {"$ref": "#/$defs/genealogy"}, "genealogy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "render_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "selector": {"type": "object", "additionalProperties": false, "required": ["type", "exact", "prefix", "suffix"], "properties": {"type": {"const": "TextQuoteSelector"}, "exact": {"type": "string", "minLength": 120}, "prefix": {"type": "string", "minLength": 3}, "suffix": {"type": "string", "minLength": 20}}}
      }
    },
    "genealogy": {
      "type": "object", "additionalProperties": false,
      "required": ["thesis_node_ids", "argument_ids", "claim_ids", "graph_path_ids", "graph_edge_ids", "source_ids", "chunk_ids", "locators", "content_hashes"],
      "properties": {
        "thesis_node_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "argument_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "claim_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "graph_path_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "graph_edge_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "source_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "chunk_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "locators": {"type": "array", "minItems": 1, "items": {"type": "object"}},
        "content_hashes": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
      }
    },
    "score": {
      "type": "object", "additionalProperties": false, "required": ["total_basis_points", "dimensions", "maximum_basis_points"],
      "properties": {"total_basis_points": {"type": "integer", "minimum": 0, "maximum": 10000}, "maximum_basis_points": {"const": 10000}, "dimensions": {"type": "object", "additionalProperties": false, "required": ["genealogy", "boundary", "objections", "falsifiers", "profile_order", "proof_gaps"], "properties": {"genealogy": {"type": "integer"}, "boundary": {"type": "integer"}, "objections": {"type": "integer"}, "falsifiers": {"type": "integer"}, "profile_order": {"type": "integer"}, "proof_gaps": {"type": "integer"}}}}
    },
    "structureScore": {
      "type": "object", "additionalProperties": false,
      "required": ["mode", "permutations_evaluated", "planned_order", "planned_score", "maximum_total_basis_points", "optimal_order_count", "planned_is_optimal", "example_optimal_order"],
      "properties": {
        "mode": {"const": "structural_stress_test_not_truth_or_persuasion"}, "permutations_evaluated": {"const": 5040},
        "planned_order": {"type": "array", "minItems": 7, "maxItems": 7, "uniqueItems": true, "items": {"type": "string"}},
        "planned_score": {"$ref": "#/$defs/score"}, "maximum_total_basis_points": {"type": "integer", "minimum": 0, "maximum": 10000},
        "optimal_order_count": {"type": "integer", "minimum": 1}, "planned_is_optimal": {"type": "boolean"},
        "example_optimal_order": {"type": "array", "minItems": 7, "maxItems": 7, "uniqueItems": true, "items": {"type": "string"}}
      }
    }
  }
}
