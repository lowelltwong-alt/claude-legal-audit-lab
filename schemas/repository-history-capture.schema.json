{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/claude-legal-audit/repository-history-capture.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "capture_id", "captured_at", "repository_url", "capture_method", "capture_scope", "pinned_commit", "clone_evidence", "raw_snapshot", "categories", "comparison_policy", "completeness", "limitations"],
  "properties": {
    "schema": {"const": "claude-legal-audit.repository-history-capture.v1"},
    "capture_id": {"type": "string", "pattern": "^HISTCAP-[0-9]{4}-[0-9]{2}-[0-9]{2}-[A-Z0-9-]+$"},
    "captured_at": {"type": "string", "format": "date-time"},
    "repository_url": {"type": "string", "format": "uri"},
    "capture_method": {"const": "local_git_metadata_snapshot"},
    "capture_scope": {"const": "local_ref_snapshot_only"},
    "pinned_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "clone_evidence": {"type": "object", "required": ["is_shallow", "promisor_remote", "partial_clone_filter", "fsck_command"], "properties": {"is_shallow": {"type": "boolean"}, "promisor_remote": {"type": "boolean"}, "partial_clone_filter": {"type": ["string", "null"]}, "fsck_command": {"type": "string"}}},
    "raw_snapshot": {"type": "object", "required": ["path", "sha256", "generator"], "properties": {"path": {"const": "results/history-local-snapshot.json"}, "sha256": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}, "generator": {"const": "scripts/build_history_capture_receipt.py"}}},
    "categories": {"type": "array", "minItems": 4, "items": {"type": "object", "required": ["kind", "capture_status", "coverage", "limitation"], "properties": {"kind": {"enum": ["refs", "commits", "pull_requests", "issues", "releases"]}, "capture_status": {"enum": ["local_metadata_captured", "not_captured"]}, "coverage": {"type": "string"}, "limitation": {"type": "string"}}}},
    "comparison_policy": {"type": "string", "minLength": 20},
    "completeness": {"type": "object", "required": ["status", "remote_pagination_verified", "deleted_history_verified", "missing_head_object_count"], "properties": {"status": {"const": "local_snapshot_incomplete_for_remote_history"}, "remote_pagination_verified": {"const": false}, "deleted_history_verified": {"const": false}, "missing_head_object_count": {"type": "integer", "minimum": 0}}},
    "limitations": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 15}}
  }
}
