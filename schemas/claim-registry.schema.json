{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/claude-legal-audit/claim-registry.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "revision", "reviewed_at", "claims"],
  "properties": {
    "schema": {"const": "claude-legal-audit.claim-registry.v2"},
    "revision": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "reviewed_at": {"type": "string", "format": "date-time"},
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/claim"}
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_id", "locator", "locator_kind", "evidence_grade", "support_type"],
      "properties": {
        "source_id": {"type": "string", "pattern": "^SRC-[0-9]{4}$"},
        "locator": {"type": "string", "minLength": 1},
        "locator_kind": {"type": "string", "minLength": 1},
        "evidence_grade": {"enum": ["reproducible", "locator_only", "unavailable"]},
        "support_type": {"type": "string", "minLength": 1}
      }
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id", "lifecycle", "epistemic_status", "review_state",
        "publication_eligibility", "proposition", "evidence", "does_not_prove",
        "confidence", "hypotheses", "repair_note"
      ],
      "properties": {
        "claim_id": {"type": "string", "pattern": "^CLM-[0-9]{4}$"},
        "lifecycle": {"enum": ["active", "superseded", "retired"]},
        "epistemic_status": {"enum": ["observed", "counterevidence", "hypothesis", "normative", "unknown"]},
        "review_state": {"enum": ["candidate", "reviewed", "rejected"]},
        "publication_eligibility": {"enum": ["eligible", "blocked_review", "quarantined", "retired"]},
        "proposition": {"type": "string", "minLength": 20},
        "evidence": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/evidence"}},
        "does_not_prove": {"type": "string", "minLength": 15},
        "confidence": {"enum": ["low", "medium", "high"]},
        "hypotheses": {
          "type": "object",
          "additionalProperties": false,
          "required": ["H0", "H1", "H2"],
          "properties": {
            "H0": {"enum": ["supports", "neutral", "weighs_against"]},
            "H1": {"enum": ["supports", "neutral", "weighs_against"]},
            "H2": {"enum": ["supports", "neutral", "weighs_against"]}
          }
        },
        "repair_note": {"type": "string", "minLength": 10},
        "supersedes": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^CLM-[0-9]{4}$"}}
      }
    }
  }
}
