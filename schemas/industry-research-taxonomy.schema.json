{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/claude-legal-audit/industry-research-taxonomy.schema.json",
  "title": "Cross-industry ontology exposure research taxonomy",
  "type": "object",
  "required": ["schema", "methodology_version", "methodology_document", "epistemic_boundary", "facets", "priority_formula", "industries"],
  "properties": {
    "schema": {"const": "claude-legal-audit.industry-research-taxonomy.v1"},
    "methodology_version": {"const": "1.0.0"},
    "industries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["industry_id", "name", "epistemic_status", "priority", "facets", "workflow_archetypes", "source_ids", "observed_market_direction", "does_not_prove"],
        "properties": {
          "industry_id": {"type": "string", "pattern": "^IND-[A-Z0-9-]+$"},
          "epistemic_status": {"enum": ["Observed", "Inferred", "Hypothesis", "Unknown"]},
          "priority": {"enum": ["P0", "P1", "P2", "P3"]},
          "facets": {
            "type": "object",
            "required": ["O", "F", "X", "C", "P", "E"],
            "additionalProperties": false,
            "properties": {
              "O": {"type": ["integer", "null"], "minimum": 0, "maximum": 3},
              "F": {"type": ["integer", "null"], "minimum": 0, "maximum": 3},
              "X": {"type": ["integer", "null"], "minimum": 0, "maximum": 3},
              "C": {"type": ["integer", "null"], "minimum": 0, "maximum": 3},
              "P": {"type": ["integer", "null"], "minimum": 0, "maximum": 3},
              "E": {"type": ["integer", "null"], "minimum": 0, "maximum": 3}
            }
          },
          "source_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^SRC-[0-9]{4}$"}},
          "does_not_prove": {"type": "string", "minLength": 20}
        }
      }
    }
  }
}

