{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/claude-legal-audit/evidence-graph.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "revision", "status", "edge_library_sha256", "input_sha256", "summary", "nodes", "edges", "limitations"],
  "properties": {
    "schema": {"const": "claude-legal-audit.evidence-graph.v1"},
    "revision": {"const": "1.0.0"},
    "status": {"const": "candidate"},
    "edge_library_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_sha256": {"type": "object", "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}},
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["node_count", "edge_count", "node_type_counts", "edge_type_counts", "eligible_claim_count", "blocked_claim_count"],
      "properties": {
        "node_count": {"type": "integer", "minimum": 1},
        "edge_count": {"type": "integer", "minimum": 1},
        "node_type_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "edge_type_counts": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
        "eligible_claim_count": {"type": "integer", "minimum": 0},
        "blocked_claim_count": {"type": "integer", "minimum": 0}
      }
    },
    "nodes": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/node"}},
    "edges": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/edge"}},
    "limitations": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 15}}
  },
  "$defs": {
    "freshness": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "as_of", "stale_after"],
      "properties": {
        "status": {"enum": ["immutable", "current_observation", "candidate", "stale", "unknown"]},
        "as_of": {"type": ["string", "null"]},
        "stale_after": {"type": ["string", "null"]}
      }
    },
    "validity": {
      "type": "object", "additionalProperties": false,
      "required": ["valid_from", "valid_to"],
      "properties": {"valid_from": {"type": ["string", "null"]}, "valid_to": {"type": ["string", "null"]}}
    },
    "node": {
      "type": "object", "additionalProperties": false,
      "required": ["node_id", "node_type", "revision", "authority", "classification", "creation_method", "review_state", "evidence_refs", "observation_time", "validity", "freshness", "attributes"],
      "properties": {
        "node_id": {"type": "string", "minLength": 3},
        "node_type": {"enum": ["repository", "revision", "pr", "commit", "file", "chunk", "source", "capture", "claim", "argument_object", "paper_section", "proof_gap"]},
        "revision": {"type": "string", "minLength": 1},
        "authority": {"enum": ["primary_source", "registered_source", "deterministic_derivative", "candidate_analysis"]},
        "classification": {"enum": ["public_primary", "public_normalized", "candidate_evidence", "candidate_argument", "candidate_paper"]},
        "creation_method": {"enum": ["git_object", "public_capture_receipt", "deterministic_builder", "registered_manual_research", "candidate_authoring"]},
        "review_state": {"enum": ["candidate", "reviewed", "rejected"]},
        "evidence_refs": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "observation_time": {"type": ["string", "null"]},
        "validity": {"$ref": "#/$defs/validity"},
        "freshness": {"$ref": "#/$defs/freshness"},
        "attributes": {"oneOf": [
          {"$ref": "#/$defs/repositoryAttributes"}, {"$ref": "#/$defs/revisionAttributes"},
          {"$ref": "#/$defs/prAttributes"}, {"$ref": "#/$defs/commitAttributes"},
          {"$ref": "#/$defs/fileAttributes"}, {"$ref": "#/$defs/chunkAttributes"},
          {"$ref": "#/$defs/sourceAttributes"}, {"$ref": "#/$defs/captureAttributes"},
          {"$ref": "#/$defs/claimAttributes"}, {"$ref": "#/$defs/argumentAttributes"},
          {"$ref": "#/$defs/paperAttributes"}, {"$ref": "#/$defs/gapAttributes"}
        ]}
      }
    },
    "repositoryAttributes": {"type":"object","additionalProperties":false,"required":["kind","repository","url"],"properties":{"kind":{"const":"repository"},"repository":{"type":"string"},"url":{"type":"string","format":"uri"}}},
    "revisionAttributes": {"type":"object","additionalProperties":false,"required":["kind","repository_id","commit_sha"],"properties":{"kind":{"const":"revision"},"repository_id":{"type":"string"},"commit_sha":{"type":"string","pattern":"^[0-9a-f]{40}$"}}},
    "prAttributes": {"type":"object","additionalProperties":false,"required":["kind","pr_number","state","html_url","event_time","capture_status"],"properties":{"kind":{"const":"pr"},"pr_number":{"type":"integer","minimum":1},"state":{"type":"string"},"html_url":{"type":"string","format":"uri"},"event_time":{"type":"object"},"capture_status":{"type":"string"}}},
    "commitAttributes": {"type":"object","additionalProperties":false,"required":["kind","sha","repository_id"],"properties":{"kind":{"const":"commit"},"sha":{"type":"string","pattern":"^[0-9a-f]{40}$"},"repository_id":{"type":"string"}}},
    "fileAttributes": {"type":"object","additionalProperties":false,"required":["kind","repository_id","path","git_blob_oid","content_sha256"],"properties":{"kind":{"const":"file"},"repository_id":{"type":"string"},"path":{"type":"string"},"git_blob_oid":{"type":["string","null"]},"content_sha256":{"type":["string","null"]}}},
    "chunkAttributes": {"type":"object","additionalProperties":false,"required":["kind","chunk_kind","content_sha256","parent_file_id","locator"],"properties":{"kind":{"const":"chunk"},"chunk_kind":{"type":"string"},"content_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"parent_file_id":{"type":"string"},"locator":{"type":"object"}}},
    "sourceAttributes": {"type":"object","additionalProperties":false,"required":["kind","title","url","source_class","status","revision_binding"],"properties":{"kind":{"const":"source"},"title":{"type":"string"},"url":{"type":"string","format":"uri"},"source_class":{"type":"string"},"status":{"type":"string"},"revision_binding":{"type":"object"}}},
    "captureAttributes": {"type":"object","additionalProperties":false,"required":["kind","capture_kind","custody_id","sha256","url"],"properties":{"kind":{"const":"capture"},"capture_kind":{"type":"string"},"custody_id":{"type":"string"},"sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"url":{"type":"string","format":"uri"}}},
    "claimAttributes": {"type":"object","additionalProperties":false,"required":["kind","lifecycle","epistemic_status","publication_eligibility","proposition","does_not_prove"],"properties":{"kind":{"const":"claim"},"lifecycle":{"enum":["active","superseded","retired"]},"epistemic_status":{"type":"string"},"publication_eligibility":{"type":"string"},"proposition":{"type":"string"},"does_not_prove":{"type":"string"}}},
    "argumentAttributes": {"type":"object","additionalProperties":false,"required":["kind","argument_type","title","statement","epistemic_status"],"properties":{"kind":{"const":"argument_object"},"argument_type":{"type":"string"},"title":{"type":"string"},"statement":{"type":"string"},"epistemic_status":{"type":"string"}}},
    "paperAttributes": {"type":"object","additionalProperties":false,"required":["kind","title","order"],"properties":{"kind":{"const":"paper_section"},"title":{"type":"string"},"order":{"type":"integer","minimum":1}}},
    "gapAttributes": {"type":"object","additionalProperties":false,"required":["kind","title","statement"],"properties":{"kind":{"const":"proof_gap"},"title":{"type":"string"},"statement":{"type":"string"}}},
    "edge": {
      "type": "object", "additionalProperties": false,
      "required": ["edge_id", "edge_type", "source_node_id", "target_node_id", "inverse_edge_id", "revision", "authority", "classification", "creation_method", "review_state", "evidence_refs", "observation_time", "validity", "freshness", "basis", "limitation"],
      "properties": {
        "edge_id": {"type":"string","pattern":"^gedge:sha256:[0-9a-f]{64}$"},
        "edge_type": {"type":"string","pattern":"^[A-Z][A-Z0-9_]+$"},
        "source_node_id": {"type":"string"}, "target_node_id": {"type":"string"},
        "inverse_edge_id": {"type":"string","pattern":"^gedge:sha256:[0-9a-f]{64}$"},
        "revision": {"type":"string"},
        "authority": {"enum":["primary_source","registered_source","deterministic_derivative","candidate_analysis"]},
        "classification": {"enum":["public_primary","public_normalized","candidate_evidence","candidate_argument","candidate_paper"]},
        "creation_method": {"enum":["git_object","public_capture_receipt","deterministic_builder","registered_manual_research","candidate_authoring"]},
        "review_state": {"enum":["candidate","reviewed","rejected"]},
        "evidence_refs": {"type":"array","uniqueItems":true,"items":{"type":"string"}},
        "observation_time": {"type":["string","null"]},
        "validity": {"$ref":"#/$defs/validity"}, "freshness": {"$ref":"#/$defs/freshness"},
        "basis": {"type":"string","minLength":10}, "limitation": {"type":"string","minLength":10}
      }
    }
  }
}
