{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/claude-legal-audit/chunk-id-migration.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "from_registry_schema", "to_registry_schema", "source_policy_revision", "source_policy_sha256", "target_policy_revision", "source_registry_sha256", "target_registry_sha256", "mappings", "status", "limitation"],
  "properties": {
    "schema": {"const": "claude-legal-audit.chunk-id-migration.v1"},
    "from_registry_schema": {"const": "claude-legal-audit.chunk-registry.v1"},
    "to_registry_schema": {"const": "claude-legal-audit.chunk-registry.v2"},
    "source_policy_revision": {"const": "1.0.0"},
    "source_policy_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "target_policy_revision": {"const": "2.0.0"},
    "source_registry_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "target_registry_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["old_chunk_id", "new_chunk_id", "chunk_kind", "parent_id", "locator", "content_sha256"],
        "properties": {
          "old_chunk_id": {"type": "string", "pattern": "^CHK-[0-9A-F]{16}$"},
          "new_chunk_id": {"type": "string", "pattern": "^chk:sha256:[0-9a-f]{64}$"},
          "chunk_kind": {"const": "static_file_span"},
          "parent_id": {"type": "string", "minLength": 10},
          "locator": {"type": "object"},
          "content_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    },
    "status": {"const": "candidate_compatibility_map"},
    "limitation": {"type": "string", "minLength": 80}
  }
}
