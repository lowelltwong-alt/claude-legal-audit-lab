{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/claude-legal-audit/release-readiness.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "revision", "as_of", "status", "authority_boundary", "inventory_snapshot", "private_path_patterns", "release_candidate", "decisions", "receipts", "required_validator_commands", "release_blockers", "human_release_approved", "human_approval"],
  "properties": {
    "schema": {"const": "claude-legal-audit.release-readiness.v1"},
    "revision": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "as_of": {"type": "string", "format": "date-time"},
    "status": {"enum": ["blocked", "ready"]},
    "authority_boundary": {"type": "string", "minLength": 30},
    "inventory_snapshot": {
      "type": "object", "additionalProperties": false,
      "required": ["tracked_file_count", "untracked_public_candidate_count", "public_path_sha256", "generated_from"],
      "properties": {
        "tracked_file_count": {"type": "integer", "minimum": 0},
        "untracked_public_candidate_count": {"type": "integer", "minimum": 0},
        "public_path_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "generated_from": {"const": "git ls-files --cached plus --others --exclude-standard, NUL-delimited, sorted"}
      }
    },
    "private_path_patterns": {"type": "array", "const": [".private/", "private/"]},
    "release_candidate": {
      "type": "object", "additionalProperties": false,
      "required": ["frozen", "commit", "allowlist_path", "allowlist_sha256", "export_path", "export_sha256"],
      "properties": {
        "frozen": {"type": "boolean"}, "commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
        "allowlist_path": {"type": ["string", "null"]}, "allowlist_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "export_path": {"type": ["string", "null"]}, "export_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "decisions": {"type": "array", "minItems": 6, "items": {"$ref": "#/$defs/decision"}},
    "receipts": {"type": "array", "minItems": 8, "items": {"$ref": "#/$defs/receipt"}},
    "required_validator_commands": {"type": "array", "minItems": 5, "items": {"type": "string", "minLength": 10}},
    "release_blockers": {"type": "array", "items": {"type": "string", "minLength": 3}},
    "human_release_approved": {"type": "boolean"},
    "human_approval": {
      "oneOf": [
        {"type": "null"},
        {"type": "object", "additionalProperties": false, "required": ["approver", "approved_at", "export_sha256", "evidence_refs"], "properties": {
          "approver": {"type": "string", "minLength": 3},
          "approved_at": {"type": "string", "format": "date-time"},
          "export_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 3}}
        }}
      ]
    }
  },
  "$defs": {
    "decision": {
      "type": "object", "additionalProperties": false,
      "required": ["decision_id", "subject", "status", "value", "evidence_refs"],
      "properties": {
        "decision_id": {"type": "string", "pattern": "^REL-DEC-[0-9]{3}$"}, "subject": {"type": "string", "minLength": 5},
        "status": {"enum": ["pending", "decided", "deferred"]}, "value": {"type": ["string", "null"]},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "receipt": {
      "type": "object", "additionalProperties": false,
      "required": ["receipt_id", "subject", "status", "evidence_refs", "limitation"],
      "properties": {
        "receipt_id": {"type": "string", "pattern": "^REL-RCP-[0-9]{3}$"}, "subject": {"type": "string", "minLength": 5},
        "status": {"enum": ["pending", "passed", "failed", "waived"]},
        "evidence_refs": {"type": "array", "items": {"type": "string"}}, "limitation": {"type": "string", "minLength": 10}
      }
    }
  }
}
