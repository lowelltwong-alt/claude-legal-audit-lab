    "law_firm_value_chain": "registry/law-firm-value-chain.json",
    "counterfactual_patterns": "registry/counterfactual-capture-patterns.json",
    "argument_method": "docs/ARGUMENT_MESH_STANDARD.md",
    "argument_mesh": "registry/argument-mesh.json",
    "contribution_policy": "CONTRIBUTING.md",
