    "UPSTREAM.lock.json",
    "registry/project-roadmap.json",
    "registry/release-readiness.json",
    "registry/source-registry.json",
    "registry/repository-history-capture.json",
    "schemas/",
    "registry/chunk-policy.json",
    "registry/claim-registry.json",
    "registry/edge-type-library.json",
    "registry/argument-mesh.json",
